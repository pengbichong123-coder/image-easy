# PostgreSQL (docker-compose starts it on 5433)
DATABASE_URL="postgresql://image_easy:image_easy_dev_pw@localhost:5433/image_easy?schema=public"

# NextAuth (Google OAuth)
AUTH_SECRET="replace-with-32+-char-random-string"
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Kie.ai
KIE_API_KEY="your-kie-api-key"
KIE_API_BASE="https://api.kie.ai"
KIE_CALLBACK_SECRET=

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe
ENABLE_PAID_CREDITS=false
STRIPE_PRICE_ENV=sandbox
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_SIGNED_URL_TTL_SECONDS=3600
